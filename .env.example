# ─────────────────── Supabase (already present) ───────────────────
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJhbGci..."   # anon key
SUPABASE_SERVICE_ROLE_KEY="eyJhbGci..."  # SERVER-ONLY. required for Paddle webhook.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGci..."

# ─────────────────── Paddle Billing ───────────────────
# Get these from https://vendors.paddle.com  →  Developer Tools

# CLIENT-SIDE (safe to expose in the browser)
VITE_PADDLE_CLIENT_TOKEN="live_xxxxxxxxxxxxxxxxxxxxxxxx"   # or test_...
VITE_PADDLE_ENVIRONMENT="production"                        # or "sandbox"
VITE_PADDLE_PRICE_UNLIMITED_PLUS="pri_01xxxxxxxxxxxxxxxx"   # $9/mo price id
VITE_PADDLE_PRICE_INFINITY="pri_01xxxxxxxxxxxxxxxx"         # $29/mo price id

# SERVER-SIDE (never expose to browser)
PADDLE_API_KEY="pdl_live_apikey_xxxxxxxxxxxxxxxx"           # or pdl_sdbx_...
PADDLE_ENV="production"                                     # or "sandbox"
PADDLE_WEBHOOK_SECRET="pdl_ntfset_xxxxxxxxxxxxxxxx"         # notification secret
# These must mirror the VITE_ price ids so the webhook can map price → tier
PADDLE_PRICE_UNLIMITED_PLUS="pri_01xxxxxxxxxxxxxxxx"
PADDLE_PRICE_INFINITY="pri_01xxxxxxxxxxxxxxxx"

# Existing app secrets
LOVABLE_API_KEY="..."

# ─────────────────── Realistic voice (TTS) ───────────────────
# The tutorial + mic use a three-tier voice pipeline:
#   1. ElevenLabs neural voices (BEST — get a free key at elevenlabs.io)
#   2. OpenAI TTS via the Lovable AI Gateway (needs LOVABLE_API_KEY)
#   3. Best available browser SpeechSynthesis voice (auto-picks the best
#      installed neural voice — Samantha, Google UK Female, MS Aria Online,
#      etc. — never the low-quality default robot voice)
#
# Without any of these set, users still hear a decent OS neural voice via
# tier 3. But ElevenLabs is dramatically more realistic — add the key here
# if you want top-quality voice.
ELEVENLABS_API_KEY=""
